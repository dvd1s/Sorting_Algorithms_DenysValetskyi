# Ask user for list size
_________________________

n = int(input("Enter number of elements: "))   # user enters the size of the list

# Create test data
data = random_list(n)   # generate random list


# Run tests
print("Bubble:", test_sort(bubble_sort, data))
print("Selection:", test_sort(selection_sort, data))
print("Quick:", test_sort(quick_sort, data))
print("Insertion:", test_sort(insertion_sort, data))
print("Merge:", test_sort(merge_sort, data))

